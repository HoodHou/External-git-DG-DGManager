<Window x:Class="SVNManager.Views.SpreadsheetMerge.MergeReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1480"
        Height="880"
        MinWidth="1200"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        Background="#F8FAFC">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <Style TargetType="{x:Type DataGridCell}">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                            <Border Background="Transparent">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type DataGridRow}">
                <Setter Property="MinHeight" Value="30" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#EFF6FF" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="Background" Value="#F1F5F9" />
                <Setter Property="Foreground" Value="#334155" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="BorderBrush" Value="#E2E8F0" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>

            <DataTemplate x:Key="RecordCellTemplate">
                <StackPanel Margin="8,5">
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,5,0,0"
                                Visibility="{Binding IsRowLevel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="采纳"
                                Command="{Binding AdoptRowCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinHeight="26"
                                Padding="10,2"
                                Margin="0,0,6,0" />
                        <Button Content="忽略"
                                Command="{Binding IgnoreRowCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinHeight="26"
                                Padding="10,2"
                                Margin="0,0,6,0" />
                        <TextBlock Text="{Binding RowLevelStatusText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#64748B" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Command="{Binding NextConflictCommand}" />
        <KeyBinding Key="N" Modifiers="Shift" Command="{Binding PrevConflictCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoLastDecisionCommand}" />
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding WriteCommand}" />
        <KeyBinding Key="Esc" Command="{Binding CancelCommand}" />
        <KeyBinding Key="OemQuestion" Modifiers="Shift" Command="{Binding ShowHelpCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="86" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <!-- 顶部标题 -->
        <DockPanel Grid.Row="0" Margin="16,10,16,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="经典视图"
                        Command="{Binding ClassicViewCommand}"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ClassicViewCommand}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="×" Width="36" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="三方合并 · 表格直显" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="{Binding RelativePath}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DockPanel>

        <!-- 概要 + 进度 + 过滤 + 搜索 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Right" Text="{Binding SummaryText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <ProgressBar Width="280" Height="10" Maximum="{Binding ProgressMaximum}" Value="{Binding DecidedCount, Mode=OneWay}" VerticalAlignment="Center" Foreground="#1E40AF" Background="#E2E8F0" />
                    <TextBlock Text="{Binding ProgressText}" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                </DockPanel>
                <DockPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBox DockPanel.Dock="Right" Width="250" Height="30" Padding="9,5"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="搜索字段、ID 或值" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding AutoFilterText}" Command="{Binding SetFilterCommand}" CommandParameter="AutoRemote" Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,0" Foreground="#166534" Background="#EBFFEF" />
                        <Button Content="{Binding ConflictFilterText}" Command="{Binding SetFilterCommand}" CommandParameter="Conflict" Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,0" Foreground="#9A3412" Background="#FFF7ED" />
                        <Button Content="{Binding RiskFilterText}" Command="{Binding SetFilterCommand}" CommandParameter="Risk" Style="{StaticResource RiskChipButtonStyle}" Margin="0,0,8,0" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <!-- 主体:工具条 + 表格直显 -->
        <DockPanel Grid.Row="2" Margin="12">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="◀ 上一个冲突" Command="{Binding PrevConflictCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="下一个冲突 ▶" Command="{Binding NextConflictCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="仅冲突·全用我的" Command="{Binding AllConflictsLocalCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="仅冲突·全用服务器" Command="{Binding AllConflictsRemoteCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,16,0" />
                    <Button Content="{Binding TargetLabel, StringFormat=全部用{0}}" Command="{Binding AllLocalCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="{Binding SourceLabel, StringFormat=全部用{0}}" Command="{Binding AllRemoteCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>

            <TabControl x:Name="SheetTabs" ItemsSource="{Binding Sheets}" Background="Transparent" BorderThickness="0">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding TabHeader}" Margin="4,2" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <DataGrid ItemsSource="{Binding Records}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="False"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#E2E8F0"
                                  VerticalGridLinesBrush="#E2E8F0"
                                  Background="White"
                                  BorderBrush="#E2E8F0"
                                  BorderThickness="1"
                                  ColumnWidth="170"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  Loaded="OnSheetGridLoaded" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>

        <!-- 底部 -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" Padding="16,10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="键盘帮助" Command="{Binding ShowHelpCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="撤销上一步" Command="{Binding UndoLastDecisionCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="取消" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="{Binding ApplyButtonText}" Command="{Binding WriteCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="120" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
