<Window x:Class="SVNManager.Views.SpreadsheetMerge.SpreadsheetMergeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:merge="clr-namespace:SVNManager.Views.SpreadsheetMerge.Converters"
        Title="{Binding WindowTitle}"
        Width="1400"
        Height="840"
        MinWidth="1180"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        Background="#F8FAFC">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <merge:MergeKindBrushConverter x:Key="MergeKindBrushConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="J" Command="{Binding MoveNextCommand}" />
        <KeyBinding Key="Down" Command="{Binding MoveNextCommand}" />
        <KeyBinding Key="K" Command="{Binding MovePrevCommand}" />
        <KeyBinding Key="Up" Command="{Binding MovePrevCommand}" />
        <KeyBinding Key="H" Command="{Binding KeepLocalCommand}" />
        <KeyBinding Key="L" Command="{Binding UseRemoteCommand}" />
        <KeyBinding Key="N" Command="{Binding NextConflictCommand}" />
        <KeyBinding Key="N" Modifiers="Shift" Command="{Binding PrevConflictCommand}" />
        <KeyBinding Key="Space" Command="{Binding ToggleDecisionCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoLastDecisionCommand}" />
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding WriteCommand}" />
        <KeyBinding Key="Esc" Command="{Binding CancelCommand}" />
        <KeyBinding Key="OemQuestion" Modifiers="Shift" Command="{Binding ShowHelpCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="86" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="16,10,16,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="经典视图"
                        Command="{Binding ClassicViewCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="×"
                        Width="36"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="表格三方合并"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="{Binding RelativePath}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,1,1,1"
                Padding="16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding SummaryText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                    <ProgressBar Width="280"
                                 Height="10"
                                 Maximum="{Binding ProgressMaximum}"
                                 Value="{Binding DecidedCount, Mode=OneWay}"
                                 VerticalAlignment="Center"
                                 Foreground="#1E40AF"
                                 Background="#E2E8F0" />
                    <TextBlock Text="{Binding ProgressText}"
                               Margin="12,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <DockPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBox DockPanel.Dock="Right"
                             Width="250"
                             Height="30"
                             Padding="9,5"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="搜索字段、ID、工作表或值" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding AutoFilterText}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="AutoRemote"
                                Style="{StaticResource ChipButtonStyle}"
                                Margin="0,0,8,0"
                                Foreground="#166534"
                                Background="#EBFFEF" />
                        <Button Content="{Binding ConflictFilterText}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="Conflict"
                                Style="{StaticResource ChipButtonStyle}"
                                Margin="0,0,8,0"
                                Foreground="#9A3412"
                                Background="#FFF7ED" />
                        <Button Content="{Binding RiskFilterText}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="Risk"
                                Style="{StaticResource RiskChipButtonStyle}"
                                Margin="0,0,8,0" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="改动列表"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="2,0,0,10" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Visibility="{Binding HasVisibleRows, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleButton IsChecked="{Binding IsExpanded}"
                                                      Style="{StaticResource GroupToggleStyle}">
                                            <DockPanel>
                                                <TextBlock Text="{Binding CountText}"
                                                           DockPanel.Dock="Right"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding Header}" />
                                            </DockPanel>
                                        </ToggleButton>
                                        <ItemsControl ItemsSource="{Binding VisibleRows}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource RowListButtonStyle}"
                                                            Command="{Binding DataContext.SelectRowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0"
                                                                    Width="4"
                                                                    CornerRadius="2"
                                                                    Background="{Binding Kind, Converter={StaticResource MergeKindBrushConverter}}" />
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding ListTitle}"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding ListSubtitle}"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           FontSize="12"
                                                                           Margin="0,4,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,0">
                    <TextBlock Text="{Binding SelectedHeaderText}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding SelectedRow.Sides}"
                              Margin="0,10,0,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding CardBackground}"
                                    BorderBrush="{Binding CardBorderBrush}"
                                    BorderThickness="{Binding CardBorderThickness}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0">
                                        <TextBlock Text="{Binding BadgeText}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{Binding AccentBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{Binding AccentBrush}"
                                                   FontWeight="SemiBold" />
                                    </DockPanel>
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto">
                                        <merge:DiffHighlightTextBlock TextValue="{Binding Value}"
                                                                      OldValue="{Binding Row.LocalValue}"
                                                                      NewValue="{Binding Row.RemoteValue}"
                                                                      HighlightRole="{Binding HighlightRole}"
                                                                      HighlightBrush="{Binding HighlightBrush}"
                                                                      FontFamily="Consolas"
                                                                      FontSize="15"
                                                                      TextWrapping="Wrap" />
                                    </ScrollViewer>
                                    <Button Grid.Row="2"
                                            Content="{Binding ButtonText}"
                                            Command="{Binding DataContext.AdoptSideCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanAdopt}"
                                            Visibility="{Binding ShowsAdoptButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock Text="{Binding SelectedRow.RowContextSummary}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       DockPanel.Dock="Right"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="整行上下文"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                        </DockPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding SelectedRow.RowContextFields}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Margin="0,8,0,0"
                                  RowHeaderWidth="0">
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Setter Property="MinHeight" Value="28" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentField}" Value="True">
                                            <Setter Property="Background" Value="#FEF3C7" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="字段"
                                                    Binding="{Binding FieldLabel}"
                                                    Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                            <Setter Property="Margin" Value="4,3" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BASE"
                                                    Binding="{Binding BaseValue}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="Margin" Value="4,3" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="目标"
                                                    Binding="{Binding LocalValue}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="Margin" Value="4,3" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="来源"
                                                    Binding="{Binding RemoteValue}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="Margin" Value="4,3" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="3"
                           Text="{Binding LinkHintText}"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="当前决策"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="{StaticResource TextBrush}" />
                        <ListBox ItemsSource="{Binding OperationOptions}"
                                 SelectedItem="{Binding SelectedOperationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ItemContainerStyle="{StaticResource OperationListItemStyle}"
                                 Style="{StaticResource OperationListBoxStyle}"
                                 Margin="0,10,0,16">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Content="{Binding}"
                                                 IsHitTestVisible="False"
                                                 IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=OneWay}"
                                                 Foreground="{StaticResource TextBrush}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="写入位置"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="84" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SelectedRow.WriteSheet, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,5"
                                     Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedRow.WriteAddress, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,5" />
                        </Grid>

                        <TextBlock Text="风险原因"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <Border Background="#FEF2F2"
                                BorderBrush="#FCA5A5"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,8,0,16">
                            <TextBlock Text="{Binding SelectedRow.RiskReason}"
                                       Foreground="{StaticResource RiskBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <TextBlock Text="快捷键"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="J/K 上下条目&#x0a;H 保留，L 使用来源&#x0a;N 下一冲突，Space 切换&#x0a;Ctrl+Enter 写入，Esc 取消"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   LineHeight="22"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="{StaticResource PanelBrush}"
                Padding="16,10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="键盘帮助"
                        Command="{Binding ShowHelpCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="撤销上一步"
                        Command="{Binding UndoLastDecisionCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="{Binding TargetLabel, StringFormat=全部选{0}}"
                        Command="{Binding AllLocalCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="{Binding SourceLabel, StringFormat=全部选{0}}"
                        Command="{Binding AllRemoteCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="取消"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="{Binding ApplyButtonText}"
                        Command="{Binding WriteCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="110" />
            </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
