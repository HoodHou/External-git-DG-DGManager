<UserControl x:Class="SVNManager.Views.SpreadsheetMerge.MergeCellControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SVNManager.Views.SpreadsheetMerge.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border x:Name="LayoutRoot"
            Background="{Binding CellBrush}"
            BorderBrush="{Binding BorderBrush}"
            BorderThickness="1"
            Padding="6,4"
            MouseLeftButtonUp="OnCellClick">
        <Grid>
            <conv:DiffHighlightTextBlock TextValue="{Binding TextValue}"
                                         OldValue="{Binding OldValue}"
                                         NewValue="{Binding NewValue}"
                                         HighlightRole="{Binding HighlightRole}"
                                         HighlightBrush="{Binding HighlightBrush}"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         TextWrapping="Wrap"
                                         VerticalAlignment="Center" />
            <TextBlock Text="{Binding DecisionGlyph}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#9A3412" />
            <Popup x:Name="DecisionPopup"
                   StaysOpen="False"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=LayoutRoot}"
                   AllowsTransparency="True"
                   MinWidth="380"
                   MaxWidth="540">
                <Border Background="White"
                        BorderBrush="#94A3B8"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.22" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="选择取舍" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10" />
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="基准" Width="48" Foreground="#475569" />
                            <TextBlock Text="{Binding BaseValue}" Foreground="#475569" TextWrapping="Wrap" FontFamily="Consolas" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="你的" Width="48" Foreground="#1E40AF" FontWeight="SemiBold" />
                            <conv:DiffHighlightTextBlock TextValue="{Binding LocalValue}"
                                                         OldValue="{Binding LocalValue}"
                                                         NewValue="{Binding RemoteValue}"
                                                         HighlightRole="Old"
                                                         HighlightBrush="#DBEAFE"
                                                         TextWrapping="Wrap"
                                                         FontFamily="Consolas" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="服务器" Width="48" Foreground="#166534" FontWeight="SemiBold" />
                            <conv:DiffHighlightTextBlock TextValue="{Binding RemoteValue}"
                                                         OldValue="{Binding LocalValue}"
                                                         NewValue="{Binding RemoteValue}"
                                                         HighlightRole="New"
                                                         HighlightBrush="#BBF7D0"
                                                         TextWrapping="Wrap"
                                                         FontFamily="Consolas" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="用我的" Click="OnTakeLocal" MinWidth="84" Margin="0,0,8,0" Padding="10,6" />
                            <Button Content="用服务器" Click="OnTakeRemote" MinWidth="84" Padding="10,6" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10,0,0"
                                    Visibility="{Binding SupportsManual, Converter={StaticResource BoolToVis}}">
                            <TextBox x:Name="ManualBox"
                                     Text="{Binding ManualValue, UpdateSourceTrigger=PropertyChanged}"
                                     Width="240"
                                     Padding="6,4"
                                     VerticalContentAlignment="Center" />
                            <Button Content="手填" Click="OnApplyManual" MinWidth="64" Margin="8,0,0,0" Padding="10,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
